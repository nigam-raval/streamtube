COOKIE_OPTION_SECURE=false 
COOKIE_OPTION_HTTPONLY=false
# flag
SKIP_ENV_VALIDATION=false




###########################
# MONGODB CONFIGURATION
###########################
MONGODB_URI=mongodb://admin:password@mongodb:27017
MONGODB_NAME=streamtube
MONGODB_AUTH_SOURCE=admin
MONGODB_CONNECTION_TIMEOUT=5000


#####################################
# OBJECT STORAGE (MinIO / AWS S3)
#####################################
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=password
STORAGE_BUCKET=streamtube
# User for generating STS tokens (Frontend read-only access)
STORAGE_STS_USER=stsuser
STORAGE_STS_PASSWORD=stspassword
# STORAGE_ENDPOINT is used for internal communication(service to service)
STORAGE_ENDPOINT=http://minio:9000
# STORAGE_EXTERNAL_ENDPOINT IS USED FOR external communication(frontend, presigned URL, access via STS)
STORAGE_EXTERNAL_ENDPOINT=http://localhost:9000
# Set true for MinIO, false for AWS S3
STORAGE_FORCE_PATH_STYLE=true



###########################
# POSTGRESQL CONFIGURATION
###########################
# Prisma Connection String (must match credentials above)
DATABASE_URL=postgresql://admin:password@postgres:5432/mydatabase



